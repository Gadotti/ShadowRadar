PORT=3500
NODE_ENV=development
DB_PATH=./data/shadowradar.db
JWT_SECRET=troque-por-string-aleatoria-de-alta-entropia
LOG_LEVEL=info

# Chave de criptografia AES-256-GCM para proteger a API key do Claude no banco de dados.
# Obrigatória apenas ao usar o modo "Chave direta" na tela de Configuração AI.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Ou com:   openssl rand -hex 32
ENCRYPTION_KEY=substitua-por-string-hex-de-64-caracteres-gerada-acima
